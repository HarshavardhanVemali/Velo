# ──────────────────────────────────────────────────────────────
# Velo — Environment Variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# ──────────────────────────────────────────────────────────────

# ── Gemini (required) ──────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_NAME=models/gemini-3.1-pro-preview

# ── Google OAuth (optional — needed for Calendar / Meet) ───
CLIENT_ID=your-google-oauth-client-id
CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
GOOGLE_OAUTH_TOKEN_JSON=.tokens/google_calendar_token.json

# ── AWS SES (optional — needed for email notifications) ────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_SES_SENDER_EMAIL=noreply@yourdomain.com

# ── Data ───────────────────────────────────────────────────
VELO_RUNS_DB=data/velo_runs.sqlite
